<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_wizard_form" model="ir.ui.view">
        <field name="name">restaurant.menu.product.wizard.form</field>
        <field name="model">restaurant.menu.product.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Create Sales Products">
                <sheet>
                    <p>
                        This will create a Sales product for every dish
                        that does not have one yet.
                    </p>
                </sheet>
                <footer>
                    <button name="action_create_products"
                            type="object"
                            string="Create Products"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_product_wizard" model="ir.actions.act_window">
        <field name="name">Bulk Create Sales Products</field>
        <field name="res_model">restaurant.menu.product.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_product_wizard"
              name="Bulk Create Products"
              parent="menu_root"
              action="action_product_wizard"
              sequence="20"/>

</odoo>
