<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend Contact form: show dishes supplied by this contact -->
    <record id="view_partner_form_menu_items" model="ir.ui.view">
        <field name="name">res.partner.form.menu.items</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Supplied Dishes" name="menu_items">
                    <field name="menu_item_ids" nolabel="1">
                        <tree>
                            <field name="name"/>
                            <field name="category"/>
                            <field name="price"/>
                        </tree>
                    </field>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
