<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW: table of all dishes -->
    <record id="view_menu_item_tree" model="ir.ui.view">
        <field name="name">restaurant.menu.item.tree</field>
        <field name="model">restaurant.menu.item</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="category"/>
                <field name="price"/>
                <field name="cost"/>
                <field name="margin"/>
                <field name="supplier_id"/>
            </tree>
        </field>
    </record>

    <!-- FORM VIEW: one dish, add/edit -->
    <record id="view_menu_item_form" model="ir.ui.view">
        <field name="name">restaurant.menu.item.form</field>
        <field name="model">restaurant.menu.item</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_product"
                            type="object"
                            string="Create Sales Product"
                            class="btn-primary"
                            invisible="product_id"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="price"/>
                        <field name="cost"/>
                        <field name="margin"/>
                        <field name="supplier_id"/>
                    </group>
                    <group>
                        <field name="tag_ids" widget="many2many_tags"/>
                    </group>
                    <group string="Sales">
                        <field name="product_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION: opens the list (and form when you click a row) -->
    <record id="action_menu_item" model="ir.actions.act_window">
        <field name="name">Menu Items</field>
        <field name="res_model">restaurant.menu.item</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- MENU: clickable entry in the top bar -->
    <menuitem id="menu_root" name="Restaurant Menu"/>
    <menuitem id="menu_items" name="Menu Items" parent="menu_root" action="action_menu_item"/>

</odoo>
