<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_restaurant_menu_item_tree" model="ir.ui.view">
        <field name="name">restaurant.menu.item.tree</field>
        <field name="model">restaurant.menu.item</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="category"/>
                <field name="price"/>
            </tree>
        </field>
    </record>

    <record id="view_restaurant_menu_item_form" model="ir.ui.view">
        <field name="name">restaurant.menu.item.form</field>
        <field name="model">restaurant.menu.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="price"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_restaurant_menu_item" model="ir.actions.act_window">
        <field name="name">Menu Items</field>
        <field name="res_model">restaurant.menu.item</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_restaurant_root"
        name="Restaurant Menu"
        sequence="10"/>
    <menuitem
        id="menu_restaurant_items"
        name="Menu Items"
        parent="menu_restaurant_root"
        action="action_restaurant_menu_item"
        sequence="10"/>
</odoo>
