<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="rule_menu_item_waiter_drinks" model="ir.rule">
        <field name="name">Waiter: drinks only</field>
        <field name="model_id" ref="model_restaurant_menu_item"/>
        <field name="domain_force">[('category', '=', 'drink')]</field>
        <field name="groups" eval="[(4, ref('group_restaurant_waiter'))]"/>
    </record>

</odoo>
