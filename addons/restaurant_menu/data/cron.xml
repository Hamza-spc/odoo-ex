<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Scheduled job: runs once per day -->
    <record id="ir_cron_check_missing_products" model="ir.cron">
        <field name="name">Restaurant Menu: Check Missing Products</field>
        <field name="model_id" ref="model_restaurant_menu_item"/>
        <field name="state">code</field>
        <field name="code">model.cron_check_missing_products()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

    <!-- Manual check: same logic, visible popup in Odoo -->
    <record id="action_server_check_missing_products" model="ir.actions.server">
        <field name="name">Check Missing Products</field>
        <field name="model_id" ref="model_restaurant_menu_item"/>
        <field name="state">code</field>
        <field name="code">model.action_check_missing_products()</field>
    </record>

    <menuitem id="menu_check_missing_products"
              name="Check Missing Products"
              parent="menu_root"
              action="action_server_check_missing_products"
              sequence="40"/>

</odoo>
